```gitignore
# Ignore everything by default
*

# Allow these folders
!Assets/
!Packages/
!ProjectSettings/

# Keep contents of allowed folders
!Assets/**
!Packages/**
!ProjectSettings/**

# Ignore generated Unity folders
Library/
Temp/
Obj/
Build/
Builds/
Logs/
UserSettings/

# Ignore IDE/editor files
.vs/
.idea/
.gradle/

# Ignore solution/project files
*.csproj
*.sln
*.suo
*.user
*.userprefs

# Ignore builds
*.apk
*.aab
*.app

# Ignore logs
*.log
```
